# Club Society hosted integration placeholders
# Do not paste secret values into the browser app. Store these in Cloudflare Worker secrets.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Cloudflare Pages Function admin import key for Paddle + Pint RSVPs.
# Add this as a Cloudflare Pages environment variable or secret, then paste
# the same value into Club Society > Integrations > Submission Sync.
ADMIN_SYNC_KEY=choose-a-long-random-private-key

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=events@example.com
BREVO_SENDER_NAME=Club Society
BREVO_TEMPLATE_ID=optional-brevo-template-id
CLUB_SOCIETY_PROFILE_URL=https://clubsociety.app/

META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_PAGE_ACCESS_TOKEN=your-page-access-token
FACEBOOK_PAGE_ID=your-facebook-page-id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id

TWILIO_ACCOUNT_SID=optional-for-sms-verification
TWILIO_AUTH_TOKEN=optional-for-sms-verification
TWILIO_VERIFY_SERVICE_SID=optional-for-sms-verification
